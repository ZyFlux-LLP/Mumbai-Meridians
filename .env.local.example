# ── Google Drive Gallery ─────────────────────────────────────────
# Follow the steps below to connect the media gallery to Google Drive.
#
# STEP 1 — Google Cloud Console (console.cloud.google.com)
#   1. Create a new project (or use an existing one)
#   2. Enable "Google Drive API"
#   3. Go to IAM & Admin → Service Accounts → Create Service Account
#   4. Name it e.g. "mumbai-meridians-gallery"
#   5. Click the account → Keys → Add Key → JSON → Download the file
#
# STEP 2 — Share your Drive folder
#   1. Create a folder in Google Drive for gallery photos
#   2. Right-click → Share → add the service account email (ends in @...iam.gserviceaccount.com)
#   3. Give it "Viewer" access
#   4. Copy the folder ID from the URL:
#      drive.google.com/drive/folders/THIS_PART_IS_THE_ID
#
# STEP 3 — Fill in the values below, then rename this file to .env.local

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ── EmailJS Contact Form ──────────────────────────────────────────
# Get these from https://emailjs.com → Account / Email Services / Email Templates
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
